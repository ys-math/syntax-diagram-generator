exports[`renderers — golden snapshots > matches the TikZ golden snapshot 1`] = `
"expression
% Requires \\usepackage{tikz} and \\usepackage{xcolor}
\\definecolor{sdgLine}{RGB}{57,70,86}
\\definecolor{sdgTermFill}{RGB}{238,243,251}
\\definecolor{sdgTermLine}{RGB}{58,103,168}
\\definecolor{sdgSpecFill}{RGB}{255,246,230}
\\definecolor{sdgSpecLine}{RGB}{184,134,11}
\\definecolor{sdgExcFill}{RGB}{253,236,235}
\\definecolor{sdgExcLine}{RGB}{176,65,58}
\\definecolor{sdgLabel}{RGB}{106,118,134}
\\begin{tikzpicture}[x=1pt, y=1pt]
  \\draw[line width=1.2pt, draw=sdgLine, rounded corners=10pt] (8,105) -- (8,91);
  \\draw[line width=1.2pt, draw=sdgLine, rounded corners=10pt] (8,98) -- (20,98);
  \\draw[line width=1.2pt, draw=sdgLine, rounded corners=10pt] (20,98) -- (48.9,98);
  \\draw[line width=1.2pt, draw=sdgLine, fill=white, rounded corners=3pt] (48.9,86) rectangle (100.5,110);
  \\node[font=\\ttfamily\\small] at (74.7,98) {term};
  \\draw[line width=1.2pt, draw=sdgLine, rounded corners=10pt] (100.5,98) -- (129.4,98);
  \\draw[line width=1.2pt, draw=sdgLine, rounded corners=10pt] (109.4,98) -- (129.4,98) -- (129.4,59) -- (20,59) -- (20,98) -- (40,98);
  \\draw[line width=1.2pt, draw=sdgLine, rounded corners=10pt] (40,59) -- (60,59);
  \\draw[line width=1.2pt, draw=sdgTermLine, fill=sdgTermFill, rounded corners=12pt] (60,47) rectangle (89.4,71);
  \\node[font=\\ttfamily\\small] at (74.7,59) {+};
